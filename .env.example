# Smart Backlog — Environment Variables
# Copy this file to .env and fill in your values

# LLM
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Database
DATABASE_PATH=data/smart_backlog.db

# Voice transcription (whisper / azure)
TRANSCRIPTION_ENGINE=whisper

# OCR (tesseract / vision)
OCR_ENGINE=vision
